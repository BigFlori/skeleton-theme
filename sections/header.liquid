<nav class="sw-nav" aria-label="{{ 'general.header' | t }}">
  <div class="container sw-nav__inner">

    {%- comment -%} Logo {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="sw-nav__logo" aria-label="{{ shop.name }}">
      <div class="sw-nav__logo-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v3M12 19v3M2 12h3M19 12h3M5 5l2 2M17 17l2 2M5 19l2-2M17 7l2-2" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="sw-nav__logo-text">
        <span class="display sw-nav__wordmark">Sonnwerk</span>
        <span class="mono sw-nav__tagline">Solar&nbsp;·&nbsp;Austria</span>
      </div>
    </a>

    {%- comment -%} Centre nav links {%- endcomment -%}
    <ul class="sw-nav__links hide-mobile" role="list">
      {%- for link in section.settings.menu.links -%}
        <li>
          <a href="{{ link.url }}" class="sw-nav__link">{{ link.title }}</a>
        </li>
      {%- else -%}
        <li><a href="#pakete" class="sw-nav__link">Pakete</a></li>
        <li><a href="#kategorien" class="sw-nav__link">Einzelprodukte</a></li>
        <li><a href="#rechner" class="sw-nav__link">Rechner</a></li>
        <li><a href="#ablauf" class="sw-nav__link">Ablauf</a></li>
        <li><a href="#faq" class="sw-nav__link">FAQ</a></li>
      {%- endfor -%}
    </ul>

    {%- comment -%} Right actions {%- endcomment -%}
    <div class="sw-nav__actions">

      {%- comment -%} Language / market switcher {%- endcomment -%}
      {%- if localization.available_countries.size > 1 or localization.available_languages.size > 1 -%}
        {%- form 'localization', class: 'sw-nav__locale-form' -%}
          <input type="hidden" name="return_to" value="{{ request.path }}">
          <button type="button" class="btn btn-ghost sw-nav__locale-btn" aria-haspopup="listbox">
            {%- if localization.country.iso_code == 'AT' -%}
              <svg width="16" height="12" viewBox="0 0 16 12" aria-hidden="true">
                <rect width="16" height="4" fill="#ED2939"/>
                <rect y="4" width="16" height="4" fill="#fff"/>
                <rect y="8" width="16" height="4" fill="#ED2939"/>
              </svg>
            {%- endif -%}
            <span>{{ localization.language.iso_code | upcase | slice: 0, 2 }}</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </button>
        {%- endform -%}
      {%- else -%}
        <div class="btn btn-ghost sw-nav__locale-btn" aria-hidden="true">
          <svg width="16" height="12" viewBox="0 0 16 12" aria-hidden="true">
            <rect width="16" height="4" fill="#ED2939"/>
            <rect y="4" width="16" height="4" fill="#fff"/>
            <rect y="8" width="16" height="4" fill="#ED2939"/>
          </svg>
          <span>DE</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </div>
      {%- endif -%}

      {%- comment -%} Cart button {%- endcomment -%}
      <a href="{{ routes.cart_url }}" class="btn btn-secondary sw-nav__cart" aria-label="{{ 'general.cart' | t }} ({{ cart.item_count }})">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <span class="hide-mobile">Warenkorb</span>
        {%- if cart.item_count > 0 -%}
          <span class="sw-nav__badge mono" aria-label="{{ cart.item_count }} {{ 'general.items' | t }}">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>

    </div>
  </div>
</nav>

{% stylesheet %}
.sw-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 40;
  padding: 14px 0;
  background: transparent;
  border-bottom: 1px solid transparent;
  transition: background 0.25s ease, border-color 0.25s ease, backdrop-filter 0.25s ease;
}

.sw-nav--scrolled {
  background: oklch(0.975 0.012 90 / 0.82);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border-bottom-color: var(--line-soft);
}

.sw-nav__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
}

/* Logo */
.sw-nav__logo {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
  color: var(--ink);
  flex-shrink: 0;
}

.sw-nav__logo-icon {
  width: 32px;
  height: 32px;
  background: var(--accent-deep);
  border-radius: 10px 10px 10px 2px;
  display: grid;
  place-items: center;
  color: var(--sun);
}

.sw-nav__logo-text {
  line-height: 1;
}

.sw-nav__wordmark {
  display: block;
  font-size: 22px;
}

.sw-nav__tagline {
  display: block;
  font-size: 9px;
  color: var(--ink-mute);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-top: 2px;
}

/* Centre links */
.sw-nav__links {
  display: flex;
  align-items: center;
  gap: 4px;
  flex: 1;
  justify-content: center;
  list-style: none;
  margin: 0;
  padding: 0;
}

.sw-nav__link {
  padding: 8px 14px;
  color: var(--ink-soft);
  text-decoration: none;
  font-size: 14px;
  border-radius: 8px;
  transition: color 0.2s ease, background 0.2s ease;
}

.sw-nav__link:hover {
  color: var(--ink);
  background: oklch(0.93 0.015 90);
}

/* Right actions */
.sw-nav__actions {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
}

.sw-nav__locale-form {
  display: contents;
}

.sw-nav__locale-btn {
  font-size: 13px;
  gap: 6px;
  padding: 8px 12px;
}

.sw-nav__cart {
  font-size: 14px;
  padding: 10px 16px;
}

.sw-nav__badge {
  background: var(--accent-deep);
  color: var(--accent-ink);
  font-size: 11px;
  font-weight: 600;
  padding: 2px 7px;
  border-radius: 999px;
}
{% endstylesheet %}

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "Customer account menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
