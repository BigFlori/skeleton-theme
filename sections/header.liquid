<nav class="sw-nav" aria-label="{{ 'general.header' | t }}">
  <div class="container sw-nav__inner">

    {%- comment -%} Logo {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="sw-nav__logo" aria-label="{{ shop.name }}">
      <div class="sw-nav__logo-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v3M12 19v3M2 12h3M19 12h3M5 5l2 2M17 17l2 2M5 19l2-2M17 7l2-2" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="sw-nav__logo-text">
        <span class="display sw-nav__wordmark">Sonnwerk</span>
        <span class="mono sw-nav__tagline">Solar&nbsp;·&nbsp;Austria</span>
      </div>
    </a>

    {%- comment -%} Centre nav links {%- endcomment -%}
    <ul class="sw-nav__links hide-mobile" role="list">
      {%- for link in section.settings.menu.links -%}
        <li>
          <a href="{{ link.url }}" class="sw-nav__link">{{ link.title }}</a>
        </li>
      {%- else -%}
        <li><a href="#pakete" class="sw-nav__link">Pakete</a></li>
        <li><a href="#kategorien" class="sw-nav__link">Einzelprodukte</a></li>
        <li><a href="#rechner" class="sw-nav__link">Rechner</a></li>
        <li><a href="#ablauf" class="sw-nav__link">Ablauf</a></li>
        <li><a href="#faq" class="sw-nav__link">FAQ</a></li>
      {%- endfor -%}
    </ul>

    {%- comment -%} Right actions {%- endcomment -%}
    <div class="sw-nav__actions">

      {%- comment -%} Language switcher {%- endcomment -%}
      {%- if localization.available_languages.size > 1 -%}
        <div class="sw-nav__locale-wrapper">
          {%- form 'localization', class: 'sw-nav__locale-form' -%}
            {%- assign return_path = request.path | remove_first: routes.root_url -%}
            {%- if return_path == blank -%}{%- assign return_path = '/' -%}{%- endif -%}
            <input type="hidden" name="return_to" value="{{ return_path }}">
            <button type="button" class="btn btn-ghost sw-nav__locale-btn" aria-haspopup="listbox" aria-expanded="false" data-locale-btn>
              {%- case localization.language.iso_code -%}
                {%- when 'de' -%}
                  <svg width="16" height="12" viewBox="0 0 16 12" aria-hidden="true"><rect width="16" height="4" fill="#ED2939"/><rect y="4" width="16" height="4" fill="#fff"/><rect y="8" width="16" height="4" fill="#ED2939"/></svg>
                {%- when 'en' -%}
                  <svg width="16" height="12" viewBox="0 0 16 12" aria-hidden="true"><rect width="16" height="12" fill="#012169"/><path d="M0,0 L16,12 M16,0 L0,12" stroke="#fff" stroke-width="2.4"/><path d="M0,0 L16,12 M16,0 L0,12" stroke="#C8102E" stroke-width="1.6"/><path d="M8,0 V12 M0,6 H16" stroke="#fff" stroke-width="4"/><path d="M8,0 V12 M0,6 H16" stroke="#C8102E" stroke-width="2.4"/></svg>
                {%- when 'hu' -%}
                  <svg width="16" height="12" viewBox="0 0 16 12" aria-hidden="true"><rect width="16" height="4" fill="#CE2939"/><rect y="4" width="16" height="4" fill="#fff"/><rect y="8" width="16" height="4" fill="#477050"/></svg>
                {%- else -%}
                  <svg width="16" height="12" viewBox="0 0 16 12" aria-hidden="true"><rect width="16" height="12" fill="#eee"/><text x="8" y="9" text-anchor="middle" font-size="8" fill="#666">{{ localization.language.iso_code | upcase | slice: 0, 2 }}</text></svg>
              {%- endcase -%}
              <span>{{ localization.language.iso_code | upcase | slice: 0, 2 }}</span>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </button>
            <ul class="sw-nav__locale-dropdown" role="listbox" data-locale-dropdown>
              {%- for language in localization.available_languages -%}
                {%- assign is_active = false -%}
                {%- if language.iso_code == localization.language.iso_code -%}
                  {%- assign is_active = true -%}
                {%- endif -%}
                <li role="option" aria-selected="{{ is_active }}">
                  <button type="submit" name="locale_code" value="{{ language.iso_code }}" class="sw-nav__locale-option{% if is_active %} is-active{% endif %}">
                    {{ language.endonym_name }}
                  </button>
                </li>
              {%- endfor -%}
            </ul>
          {%- endform -%}
        </div>
      {%- else -%}
        <div class="btn btn-ghost sw-nav__locale-btn" aria-hidden="true">
          <span>{{ localization.language.iso_code | upcase | slice: 0, 2 }}</span>
        </div>
      {%- endif -%}

      {%- comment -%} Cart button — opens drawer; falls back to /cart without JS {%- endcomment -%}
      <a
        href="{{ routes.cart_url }}"
        class="btn btn-secondary sw-nav__cart"
        data-cart-drawer-trigger
        aria-label="{{ 'general.cart' | t }} ({{ cart.item_count }})"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <span class="hide-mobile">{{ 'general.cart' | t }}</span>
        <span
          class="sw-nav__badge mono"
          data-cart-drawer-count
          {% if cart.item_count == 0 %} hidden{% endif %}
          aria-label="{{ cart.item_count }} {{ 'general.items' | t }}"
        >{{ cart.item_count }}</span>
      </a>

    </div>
  </div>
</nav>

{% stylesheet %}
.sw-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 40;
  padding: 14px 0;
  background: transparent;
  border-bottom: 1px solid transparent;
  transition: background 0.25s ease, border-color 0.25s ease, backdrop-filter 0.25s ease;
}

.sw-nav--scrolled {
  background: oklch(0.975 0.012 90 / 0.82);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border-bottom-color: var(--line-soft);
}

.sw-nav__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
}

/* Logo */
.sw-nav__logo {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
  color: var(--ink);
  flex-shrink: 0;
}

.sw-nav__logo-icon {
  width: 32px;
  height: 32px;
  background: var(--accent-deep);
  border-radius: 10px 10px 10px 2px;
  display: grid;
  place-items: center;
  color: var(--sun);
}

.sw-nav__logo-text {
  line-height: 1;
}

.sw-nav__wordmark {
  display: block;
  font-size: 22px;
}

.sw-nav__tagline {
  display: block;
  font-size: 9px;
  color: var(--ink-mute);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-top: 2px;
}

/* Centre links */
.sw-nav__links {
  display: flex;
  align-items: center;
  gap: 4px;
  flex: 1;
  justify-content: center;
  list-style: none;
  margin: 0;
  padding: 0;
}

.sw-nav__link {
  padding: 8px 14px;
  color: var(--ink-soft);
  text-decoration: none;
  font-size: 14px;
  border-radius: 8px;
  transition: color 0.2s ease, background 0.2s ease;
}

.sw-nav__link:hover {
  color: var(--ink);
  background: oklch(0.93 0.015 90);
}

/* Right actions */
.sw-nav__actions {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
}

.sw-nav__locale-form {
  display: contents;
}

.sw-nav__locale-wrapper {
  position: relative;
}

.sw-nav__locale-btn {
  font-size: 13px;
  gap: 6px;
  padding: 8px 12px;
}

.sw-nav__locale-dropdown {
  display: none;
  position: absolute;
  top: calc(100% + 8px);
  right: 0;
  min-width: 140px;
  background: oklch(0.99 0.008 90);
  border: 1px solid var(--line-soft);
  border-radius: 10px;
  padding: 6px;
  list-style: none;
  margin: 0;
  box-shadow: 0 8px 24px oklch(0 0 0 / 0.08);
  z-index: 50;
}

.sw-nav__locale-wrapper.is-open .sw-nav__locale-dropdown {
  display: block;
}

.sw-nav__locale-option {
  display: block;
  width: 100%;
  text-align: left;
  background: none;
  border: none;
  padding: 8px 12px;
  font-size: 13px;
  color: var(--ink-soft);
  border-radius: 7px;
  cursor: pointer;
  transition: background 0.15s ease, color 0.15s ease;
}

.sw-nav__locale-option:hover {
  background: oklch(0.93 0.015 90);
  color: var(--ink);
}

.sw-nav__locale-option.is-active {
  color: var(--ink);
  font-weight: 500;
}

.sw-nav__cart {
  font-size: 14px;
  padding: 10px 16px;
}

.sw-nav__badge {
  background: var(--accent-deep);
  color: var(--accent-ink);
  font-size: 11px;
  font-weight: 600;
  padding: 2px 7px;
  border-radius: 999px;
}
{% endstylesheet %}

{% javascript %}
document.addEventListener('DOMContentLoaded', function () {
  const wrapper = document.querySelector('.sw-nav__locale-wrapper');
  if (!wrapper) return;

  const btn = wrapper.querySelector('[data-locale-btn]');

  btn.addEventListener('click', function () {
    const open = wrapper.classList.toggle('is-open');
    btn.setAttribute('aria-expanded', open);
  });

  document.addEventListener('click', function (e) {
    if (!wrapper.contains(e.target)) {
      wrapper.classList.remove('is-open');
      btn.setAttribute('aria-expanded', 'false');
    }
  });
});
{% endjavascript %}

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "Customer account menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
