{%- liquid
  assign threshold       = section.settings.free_shipping_threshold | times: 100
  assign threshold_money = threshold | money
  assign fee             = section.settings.shipping_fee | times: 100
  if cart.total_price >= threshold
    assign shipping_free = true
    assign grand_total   = cart.total_price
  else
    assign shipping_free = false
    assign grand_total   = cart.total_price | plus: fee
  endif
  assign has_unavailable = false
  for item in cart.items
    unless item.variant.available
      assign has_unavailable = true
      break
    endunless
  endfor
-%}

{%- if cart.item_count == 0 -%}

  {%- render 'cart-empty' -%}

{%- else -%}

  {%- render 'cart-hero' -%}
  {%- render 'cart-progress', threshold: threshold, shipping_free: shipping_free -%}

  <section class="sw-cart-body" aria-label="{{ 'general.cart' | t }}">
    <div class="container">
      <div class="sw-cart-grid">

        <div class="sw-cart-items">
          <div class="mono sw-cart-items__count" data-cart-count>
            {{ cart.item_count }}&nbsp;{{ 'sections.cart.items' | t }}
          </div>
          {%- for item in cart.items -%}
            {%- assign line_index = forloop.index -%}
            {%- render 'cart-line-item', item: item, line_index: line_index, low_stock_threshold: section.settings.low_stock_threshold -%}
          {%- endfor -%}
        </div>

        {%- render 'cart-summary', grand_total: grand_total, fee: fee, shipping_free: shipping_free, has_unavailable: has_unavailable -%}

      </div>
    </div>
  </section>

  {%- render 'cart-upsell' -%}

{%- endif -%}

<div id="sw-cart-toast" class="sw-toast" aria-live="polite" aria-atomic="true" hidden></div>
<div id="sw-cart-live" class="sw-sr-only" aria-live="polite" aria-atomic="true"></div>

{% stylesheet %}

/* ── Empty state ── */
.sw-cart-empty {
  padding-top: var(--s-7);
  padding-bottom: var(--s-7);
}
.sw-cart-empty__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 20px;
}
.sw-cart-empty__icon {
  width: 72px;
  height: 72px;
  background: var(--accent-soft);
  color: var(--accent-deep);
  border-radius: 20px;
  display: grid;
  place-items: center;
}
.sw-cart-empty__title {
  font-size: clamp(36px, 6vw, 56px);
  line-height: 1.05;
}
.sw-cart-empty__body {
  color: var(--ink-soft);
  max-width: 440px;
  line-height: 1.6;
}
.sw-cart-empty__actions {
  display: flex;
  gap: 10px;
  margin-top: 8px;
  flex-wrap: wrap;
  justify-content: center;
}

/* ── Hero ── */
.sw-cart-hero {
  padding-top: var(--s-5);
  padding-bottom: var(--s-3);
}
.sw-cart-hero__meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 12px;
}
.sw-cart-hero__back {
  font-size: 13px;
  color: var(--ink-soft);
  text-decoration: none;
}
.sw-cart-hero__back:hover { color: var(--ink); }
.sw-cart-hero__title {
  font-size: clamp(44px, 6.5vw, 80px);
  line-height: 1.05;
  margin-top: 14px;
  padding-bottom: 24px;
}
.sw-cart-hero__title em {
  color: var(--accent-deep);
  font-style: italic;
}

/* ── Progress ── */
.sw-cart-progress-wrap {
  padding-bottom: var(--s-4);
}
.sw-progress {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 6px;
  padding: 14px 18px;
  background: var(--bg-card);
  border: 1px solid var(--line);
  border-radius: 999px;
}
.sw-progress__step {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 13px;
  color: var(--ink-mute);
}
.sw-progress__step--active {
  color: var(--ink);
  font-weight: 500;
}
.sw-progress__num {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  border: 1px solid var(--line);
  color: var(--ink-mute);
  display: grid;
  place-items: center;
  font-size: 10px;
  font-family: var(--font-mono);
  font-weight: 500;
  flex-shrink: 0;
}
.sw-progress__step--active .sw-progress__num {
  background: var(--accent-deep);
  border-color: var(--accent-deep);
  color: var(--accent-ink);
}

/* ── Free shipping bar ── */
.sw-free-ship-bar {
  padding-bottom: var(--s-3);
}
.sw-free-ship-bar__track {
  height: 6px;
  background: var(--line);
  border-radius: 999px;
  overflow: hidden;
  margin-bottom: 8px;
}
.sw-free-ship-bar__fill {
  height: 100%;
  background: var(--accent-deep);
  border-radius: 999px;
  transition: width 0.4s ease;
}
.sw-free-ship-bar__fill--done {
  background: #22c55e;
}
.sw-free-ship-bar__label {
  font-size: 13px;
  color: var(--ink-mute);
  margin: 0;
}

/* ── Cart body grid ── */
.sw-cart-body {
  padding-bottom: var(--s-6);
}
.sw-cart-grid {
  display: grid;
  grid-template-columns: 1.5fr 1fr;
  gap: var(--s-5);
  align-items: start;
}

/* ── Items ── */
.sw-cart-items__count {
  font-size: 12px;
  color: var(--ink-mute);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding-bottom: 12px;
}

/* ── Line item ── */
.sw-cart-line {
  display: grid;
  grid-template-columns: 96px 1fr;
  grid-template-rows: auto auto;
  grid-template-areas:
    "thumb info"
    "thumb controls";
  column-gap: 20px;
  row-gap: 14px;
  padding: 22px 0;
  border-top: 1px solid var(--line);
  align-items: start;
}
.sw-cart-line__thumb { grid-area: thumb; position: relative; }
.sw-cart-line__img {
  width: 96px;
  height: 96px;
  border-radius: 10px;
  object-fit: cover;
  display: block;
}
.sw-cart-line__img-placeholder {
  width: 96px;
  height: 96px;
  border-radius: 10px;
  background: var(--accent-soft);
}
.sw-cart-line__info { grid-area: info; min-width: 0; }
.sw-cart-line__brand {
  font-size: 10px;
  color: var(--ink-mute);
  letter-spacing: 0.06em;
  text-transform: uppercase;
}
.sw-cart-line__name {
  font-size: 22px;
  line-height: 1.15;
  margin-top: 4px;
}
.sw-cart-line__name a { color: inherit; text-decoration: none; }
.sw-cart-line__name a:hover { color: var(--accent-deep); }
.sw-cart-line__variant {
  font-size: 13px;
  color: var(--ink-soft);
  margin-top: 5px;
  line-height: 1.5;
}
.sw-cart-line__meta {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  margin-top: 12px;
  align-items: center;
}
.sw-cart-line__stock {
  font-size: 11px;
  color: var(--ink-mute);
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.sw-cart-line__stock--in  { color: var(--accent-deep); }
.sw-cart-line__stock--low { color: #964A16; }
.sw-cart-line__dot {
  display: inline-block;
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: currentColor;
  flex-shrink: 0;
}
.sw-cart-line__dot--in  { color: var(--accent-deep); }
.sw-cart-line__dot--out { color: var(--ink-mute); }
.sw-cart-line__dot--low { color: #964A16; }
.sw-cart-line__badge {
  position: absolute;
  top: -10px;
  left: -8px;
  background: #EAB132;
  color: #1a0a00;
  font-size: 9px;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  padding: 3px 8px;
  border-radius: 5px;
  line-height: 1.4;
  white-space: nowrap;
  pointer-events: none;
}
.sw-cart-line__action {
  background: transparent;
  border: none;
  cursor: pointer;
  font-size: 12px;
  color: var(--ink-mute);
  padding: 0;
  text-decoration: underline;
  text-underline-offset: 3px;
  font-family: var(--font-sans);
}
.sw-cart-line__action:hover:not(:disabled) { color: var(--accent-deep); }
.sw-cart-line__action:disabled { cursor: default; opacity: 0.45; }
.sw-cart-line__controls {
  grid-area: controls;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20px;
  flex-wrap: wrap;
}
.sw-cart-line__price { text-align: right; min-width: 110px; }
.sw-cart-line__total { font-size: 24px; line-height: 1; }
.sw-cart-line__each  { font-size: 10px; color: var(--ink-mute); margin-top: 4px; }

/* ── Qty stepper ── */
.sw-qty {
  display: inline-flex;
  align-items: center;
  border: 1px solid var(--line);
  border-radius: 999px;
  padding: 3px;
  background: var(--bg-card);
  height: 40px;
}
.sw-qty__btn {
  width: 30px;
  height: 30px;
  border: none;
  border-radius: 50%;
  background: transparent;
  cursor: pointer;
  display: grid;
  place-items: center;
  color: var(--ink);
  flex-shrink: 0;
}
.sw-qty__btn:hover { background: var(--accent-soft); color: var(--accent-deep); }
.sw-qty__input {
  width: 36px;
  border: none;
  text-align: center;
  background: transparent;
  font-size: 14px;
  font-weight: 500;
  -moz-appearance: textfield;
  appearance: textfield;
}
.sw-qty__input::-webkit-outer-spin-button,
.sw-qty__input::-webkit-inner-spin-button { -webkit-appearance: none; }

/* ── Summary ── */
.sw-cart-summary {
  position: sticky;
  top: 100px;
  display: flex;
  flex-direction: column;
  gap: 18px;
}
.sw-cart-summary__card {
  background: var(--bg-card);
  border: 1px solid var(--line);
  border-radius: var(--radius-xl);
  padding: 28px;
}
.sw-cart-summary__title { font-size: 28px; line-height: 1; }
.sw-cart-summary__rows {
  margin-top: 22px;
  display: flex;
  flex-direction: column;
}
.sw-cart-summary__row {
  display: grid;
  grid-template-columns: 1fr auto;
  font-size: 14px;
  padding: 10px 0;
  gap: 0 8px;
}
.sw-cart-summary__row dt { color: var(--ink); align-self: center; }
.sw-cart-summary__row dd { font-weight: 500; text-align: right; align-self: center; margin: 0; }
.sw-cart-summary__dd--accent { color: var(--accent-deep); }
.sw-cart-summary__sub {
  font-size: 10px;
  color: var(--ink-mute);
  grid-column: 1 / -1;
  margin-top: 2px;
}
.sw-cart-summary__total-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding-top: 20px;
  margin-top: 6px;
  border-top: 1px dashed var(--line);
}
.sw-cart-summary__total-label { font-size: 15px; font-weight: 500; }
.sw-cart-summary__total-amount { font-size: 42px; line-height: 1; }
.sw-cart-summary__checkout-btn {
  width: 100%;
  justify-content: center;
  margin-top: 20px;
  font-size: 16px;
  padding: 16px;
}
.sw-cart-summary__checkout-btn:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}
.sw-cart-summary__checkout-btn:disabled:hover {
  background: var(--accent-deep);
  transform: none;
}
.sw-cart-summary__unavailable-note {
  font-size: 13px;
  font-weight: 500;
  color: #b84a1a;
  text-align: center;
  margin-top: 10px;
  padding: 8px 12px;
  background: #fdf0ea;
  border-radius: var(--radius);
}
.sw-cart-summary__checkout-note {
  font-size: 10px;
  color: var(--ink-mute);
  text-align: center;
  margin-top: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5px;
}

/* ── Discount ── */
.sw-cart-discount {
  border-top: 1px solid var(--line);
  padding-top: 18px;
  margin-top: 18px;
}
.sw-cart-discount__label {
  display: block;
  font-size: 10px;
  color: var(--ink-mute);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 6px;
}
.sw-cart-discount__input {
  width: 100%;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  padding: 10px 12px;
  font-size: 13px;
  background: var(--bg);
  color: var(--ink);
  outline: none;
  box-sizing: border-box;
  transition: border-color 0.15s;
}
.sw-cart-discount__input:focus { border-color: var(--accent); }
.sw-cart-discount__input::placeholder { color: var(--ink-mute); }
.sw-cart-discount__note {
  font-size: 11px;
  color: var(--ink-mute);
  margin-top: 6px;
}

/* ── Payment logos ── */
.sw-cart-payment {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  padding: 12px 4px;
}
.sw-pay-logo { display: flex; align-items: center; }

/* ── Upsell ── */
.sw-cart-upsell { padding-bottom: var(--s-6); }
.sw-cart-upsell__header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: var(--s-4);
  flex-wrap: wrap;
  gap: 12px;
}
.sw-cart-upsell__title { font-size: 36px; line-height: 1; margin-top: 10px; }
.sw-cart-upsell__all { font-size: 13px; color: var(--ink-soft); text-decoration: none; white-space: nowrap; }
.sw-cart-upsell__all:hover { color: var(--ink); }
.sw-cart-upsell__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}
.sw-cart-upsell__card {
  background: var(--bg-card);
  border: 1px solid var(--line);
  border-radius: var(--radius-lg);
  padding: 18px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.sw-cart-upsell__img-wrap { border-radius: 10px; overflow: hidden; aspect-ratio: 1; }
.sw-cart-upsell__img { width: 100%; height: 100%; object-fit: cover; display: block; }
.sw-cart-upsell__img-placeholder { aspect-ratio: 1; background: var(--accent-soft); border-radius: 10px; }
.sw-cart-upsell__vendor { font-size: 10px; color: var(--ink-mute); text-transform: uppercase; letter-spacing: 0.06em; }
.sw-cart-upsell__name { font-size: 15px; font-weight: 500; margin-top: 4px; line-height: 1.3; }
.sw-cart-upsell__footer { display: flex; justify-content: space-between; align-items: center; margin-top: auto; }
.sw-cart-upsell__price { font-size: 20px; }
.sw-cart-upsell__add { padding: 8px 14px; font-size: 12px; }

/* ── Toast ── */
.sw-toast {
  position: fixed;
  bottom: 28px;
  left: 50%;
  transform: translateX(-50%) translateY(10px);
  background: var(--bg-dark);
  color: var(--accent-ink);
  font-family: var(--font-sans);
  font-size: 14px;
  padding: 12px 22px;
  border-radius: 999px;
  z-index: 200;
  opacity: 0;
  transition: opacity 0.2s ease, transform 0.2s ease;
  pointer-events: none;
  white-space: nowrap;
}
.sw-toast--visible { opacity: 1; transform: translateX(-50%) translateY(0); pointer-events: auto; }
.sw-cart-line--loading   { opacity: 0.5; pointer-events: none; }
.sw-cart-line--removing  { opacity: 0.35; pointer-events: none; transition: opacity 0.15s ease; }
.sw-toast__action {
  background: transparent;
  border: none;
  cursor: pointer;
  color: var(--accent-ink);
  font-size: 14px;
  font-family: var(--font-sans);
  font-weight: 600;
  padding: 0;
  margin-left: 14px;
  text-decoration: underline;
  text-underline-offset: 2px;
}

.sw-sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }

/* ── Responsive ── */
@media (max-width: 960px) {
  .sw-cart-grid { grid-template-columns: 1fr; }
  .sw-cart-summary { position: static; }
  .sw-progress { border-radius: 16px; }
  .sw-cart-upsell__grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .sw-progress { grid-template-columns: 1fr; gap: 10px; border-radius: 16px; }
  .sw-cart-line { grid-template-columns: 72px 1fr; }
  .sw-cart-line__img,
  .sw-cart-line__img-placeholder { width: 72px; height: 72px; }
  .sw-cart-upsell__grid { grid-template-columns: 1fr 1fr; }
  .sw-cart-hero__title { font-size: clamp(36px, 10vw, 56px); }
  .sw-qty { height: 50px; }
  .sw-qty__btn { width: 44px; height: 44px; }
}

{% endstylesheet %}

<script>
window.swCartConfig = {
  threshold: {{ threshold }},
  fee: {{ fee }},
  moneyFormat: {{ shop.money_format | json }},
  strings: {
    each: {{ 'sections.cart.each' | t | json }},
    items: {{ 'sections.cart.items' | t | json }},
    shippingFree: {{ 'sections.cart.shipping_free' | t | json }},
    shippingFreeNote: {{ 'sections.cart.shipping_free_note' | t: amount: threshold_money | json }},
    shippingPaidNote: {{ 'sections.cart.shipping_paid_note' | t | json }},
    qtyMin: {{ 'sections.cart.qty_min' | t | json }},
    itemRemoved: {{ 'sections.cart.item_removed' | t | json }},
    undo: {{ 'sections.cart.undo' | t | json }},
    freeShipUnlocked: {{ 'sections.cart.shipping_bar_unlocked' | t | json }},
    freeShipProgress: {{ 'sections.cart.shipping_bar_progress' | t: amount: '__AMOUNT__' | json }},
    errorGeneric: {{ 'sections.cart.error_generic' | t | json }},
    upsellAdded: {{ 'sections.cart.upsell_added' | t | json }}
  }
};
</script>

<script>
(function () {
  var cfg          = window.swCartConfig;
  var toast          = document.getElementById('sw-cart-toast');
  var toastTimer;
  var settingValue    = false;
  var pendingRemovals = {};
  var removalTimer    = null;

  function hideToast() {
    clearTimeout(toastTimer);
    toast.classList.remove('sw-toast--visible');
    setTimeout(function () { toast.hidden = true; }, 220);
  }

  function showToast(msg, actionLabel, actionFn, duration) {
    if (!toast) return;
    clearTimeout(toastTimer);
    toast.innerHTML = '';
    toast.hidden = false;
    requestAnimationFrame(function () {
      var msgNode = document.createElement('span');
      msgNode.textContent = msg;
      toast.appendChild(msgNode);
      if (actionLabel && actionFn) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'sw-toast__action';
        btn.textContent = actionLabel;
        btn.addEventListener('click', function () { actionFn(); });
        toast.appendChild(btn);
      }
      toast.classList.add('sw-toast--visible');
    });
    toastTimer = setTimeout(function () {
      toast.classList.remove('sw-toast--visible');
      setTimeout(function () { toast.hidden = true; }, 220);
    }, duration || 4500);
  }

  function setLineLoading(lineIndex, on) {
    var el = document.querySelector('[data-line="' + lineIndex + '"]');
    if (el) el.classList.toggle('sw-cart-line--loading', on);
  }

  function formatMoney(cents) {
    var fmt = cfg.moneyFormat;
    var re  = /\{\{\s*(\w+)\s*\}\}/;
    function d(o, def) { return typeof o === 'undefined' ? def : o; }
    function delimit(n, prec, th, dec) {
      prec = d(prec, 2); th = d(th, ','); dec = d(dec, '.');
      n = (n / 100).toFixed(prec);
      var p = n.split('.');
      p[0] = p[0].replace(/(\d)(?=(\d\d\d)+(?!\d))/g, '$1' + th);
      return p[0] + (p[1] ? dec + p[1] : '');
    }
    var m = fmt.match(re);
    if (!m) return fmt;
    var val;
    switch (m[1]) {
      case 'amount':                                  val = delimit(cents, 2);        break;
      case 'amount_no_decimals':                      val = delimit(cents, 0);        break;
      case 'amount_with_comma_separator':             val = delimit(cents, 2, '.', ','); break;
      case 'amount_no_decimals_with_comma_separator':  val = delimit(cents, 0, '.', ','); break;
      case 'amount_with_space_separator':              val = delimit(cents, 2, ' ', '.'); break;
      case 'amount_no_decimals_with_space_separator':  val = delimit(cents, 0, ' ');      break;
      default:                                         val = delimit(cents, 2);
    }
    return fmt.replace(re, val);
  }

  function updateCartDOM(cart, lineIndex) {
    var shippingFree = cart.total_price >= cfg.threshold;
    var grandTotal   = shippingFree ? cart.total_price : cart.total_price + cfg.fee;

    var countEl = document.querySelector('[data-cart-count]');
    if (countEl) countEl.innerHTML = cart.item_count + ' ' + cfg.strings.items;

    var item = cart.items[lineIndex - 1];
    if (item) {
      var qtyInput = document.querySelector('[data-cart-qty="' + lineIndex + '"]');
      if (qtyInput) {
        settingValue = true;
        qtyInput.value = item.quantity;
        qtyInput.dataset.prevQty = item.quantity;
        settingValue = false;
      }

      var totalEl = document.querySelector('[data-line-total="' + lineIndex + '"]');
      if (totalEl) totalEl.textContent = formatMoney(item.line_price);

      var eachEl = document.querySelector('[data-line-each="' + lineIndex + '"]');
      if (eachEl) {
        if (item.quantity > 1) {
          eachEl.textContent = formatMoney(item.price) + ' ' + cfg.strings.each;
          eachEl.hidden = false;
        } else {
          eachEl.hidden = true;
        }
      }
    }

    var subtotalEl     = document.querySelector('[data-cart-subtotal]');
    var shippingValEl  = document.querySelector('[data-cart-shipping-value]');
    var shippingNoteEl = document.querySelector('[data-cart-shipping-note]');
    var grandTotalEl   = document.querySelector('[data-cart-grand-total]');

    if (subtotalEl)     subtotalEl.textContent     = formatMoney(cart.total_price);
    if (shippingValEl)  shippingValEl.textContent  = shippingFree ? cfg.strings.shippingFree : formatMoney(cfg.fee);
    if (shippingNoteEl) shippingNoteEl.textContent = shippingFree ? cfg.strings.shippingFreeNote : cfg.strings.shippingPaidNote;
    if (grandTotalEl)   grandTotalEl.textContent   = formatMoney(grandTotal);

    var liveEl = document.getElementById('sw-cart-live');
    if (liveEl) liveEl.textContent = cart.item_count + ' ' + cfg.strings.items + ' — ' + formatMoney(grandTotal);

    var freeShipFill  = document.querySelector('[data-free-ship-fill]');
    var freeShipLabel = document.querySelector('[data-free-ship-label]');
    var freeShipTrack = freeShipFill && freeShipFill.closest('[role="progressbar"]');
    if (freeShipFill) {
      var pct = Math.min(100, Math.round(cart.total_price / cfg.threshold * 100));
      freeShipFill.style.width = pct + '%';
      if (freeShipTrack) freeShipTrack.setAttribute('aria-valuenow', pct);
      if (shippingFree) {
        freeShipFill.classList.add('sw-free-ship-bar__fill--done');
        if (freeShipLabel) freeShipLabel.textContent = cfg.strings.freeShipUnlocked;
      } else {
        freeShipFill.classList.remove('sw-free-ship-bar__fill--done');
        if (freeShipLabel) {
          var rem = cfg.threshold - cart.total_price;
          freeShipLabel.textContent = cfg.strings.freeShipProgress.replace('__AMOUNT__', formatMoney(rem));
        }
      }
    }

    setLineLoading(lineIndex, false);
  }

  function getFocusTargetAfterRemoval(lineIndex) {
    var next = document.querySelector('[data-line="' + (lineIndex + 1) + '"]');
    if (next) return next.querySelector('[data-cart-remove]') || next.querySelector('a') || next;
    var prev = document.querySelector('[data-line="' + (lineIndex - 1) + '"]');
    if (prev) return prev.querySelector('[data-cart-remove]') || prev.querySelector('a') || prev;
    var countEl = document.querySelector('[data-cart-count]');
    if (countEl) { if (!countEl.getAttribute('tabindex')) countEl.setAttribute('tabindex', '-1'); return countEl; }
    return null;
  }

  function reindexLines(removedIndex) {
    var i = removedIndex + 1;
    while (true) {
      var el = document.querySelector('[data-line="' + i + '"]');
      if (!el) break;
      var n = i - 1;
      el.dataset.line = n;
      var dec = el.querySelector('[data-cart-dec]');   if (dec)   dec.dataset.cartDec   = n;
      var inc = el.querySelector('[data-cart-inc]');   if (inc)   inc.dataset.cartInc   = n;
      var rem = el.querySelector('[data-cart-remove]');if (rem)   rem.dataset.cartRemove = n;
      var qty = el.querySelector('[data-cart-qty]');   if (qty)   qty.dataset.cartQty   = n;
      var tot = el.querySelector('[data-line-total]'); if (tot)   tot.dataset.lineTotal  = n;
      var ech = el.querySelector('[data-line-each]');  if (ech)   ech.dataset.lineEach   = n;
      i++;
    }
  }

  async function changeQty(lineIndex, newQty) {
    setLineLoading(lineIndex, true);
    try {
      var res = await fetch('/cart/change.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
          'Accept': 'application/json'
        },
        body: 'line=' + lineIndex + '&quantity=' + newQty
      });
      if (!res.ok) {
        var errData = null;
        try { errData = await res.json(); } catch (_) {}
        console.error('[sw-cart] change failed:', res.status, errData);
        var apiError = errData ? (errData.description || errData.message) : null;
        throw new Error(apiError || cfg.strings.errorGeneric);
      }
      var cart = await res.json();
      if (newQty === 0) {
        if (cart.item_count === 0) {
          location.reload();
        } else {
          updateCartDOM(cart, lineIndex);
          var lineEl   = document.querySelector('[data-line="' + lineIndex + '"]');
          var focusEl  = getFocusTargetAfterRemoval(lineIndex);
          if (lineEl) lineEl.remove();
          reindexLines(lineIndex);
          if (focusEl) focusEl.focus();
        }
      } else {
        updateCartDOM(cart, lineIndex);
      }
    } catch (err) {
      console.error('[sw-cart]', err.message);
      setLineLoading(lineIndex, false);
      var failedInput = document.querySelector('[data-cart-qty="' + lineIndex + '"]');
      if (failedInput && failedInput.dataset.prevQty) {
        settingValue = true;
        failedInput.value = failedInput.dataset.prevQty;
        settingValue = false;
      }
      var msg = (err.message === 'Failed to fetch' || err.message.indexOf('HTTP') === 0)
        ? cfg.strings.errorGeneric
        : err.message;
      showToast(msg || cfg.strings.errorGeneric);
    }
  }

  async function commitPendingRemovals() {
    var indices = Object.keys(pendingRemovals).map(Number).sort(function (a, b) { return b - a; });
    pendingRemovals = {};
    removalTimer    = null;
    for (var i = 0; i < indices.length; i++) {
      await changeQty(indices[i], 0);
    }
  }

  function scheduleRemoval(lineIndex) {
    clearTimeout(removalTimer);
    var lineEl = document.querySelector('[data-line="' + lineIndex + '"]');
    if (lineEl) lineEl.classList.add('sw-cart-line--removing');
    pendingRemovals[lineIndex] = lineEl;

    var nameEl   = lineEl ? lineEl.querySelector('.sw-cart-line__name a') : null;
    var itemName = nameEl ? nameEl.textContent.trim() : '';
    var msg      = itemName ? (itemName + ' — ' + cfg.strings.itemRemoved) : cfg.strings.itemRemoved;

    removalTimer = setTimeout(commitPendingRemovals, 5000);

    showToast(msg, cfg.strings.undo, function () {
      hideToast();
      clearTimeout(removalTimer);
      removalTimer = null;
      var el = pendingRemovals[lineIndex];
      delete pendingRemovals[lineIndex];
      if (el) el.classList.remove('sw-cart-line--removing');
      if (Object.keys(pendingRemovals).length > 0) {
        removalTimer = setTimeout(commitPendingRemovals, 5000);
      }
    }, 5000);
  }

  function getLineQty(lineIndex) {
    var input = document.querySelector('[data-cart-qty="' + lineIndex + '"]');
    return input ? (parseInt(input.value, 10) || 1) : 1;
  }

  document.addEventListener('click', function (e) {
    var dec = e.target.closest('[data-cart-dec]');
    if (dec) {
      var line = parseInt(dec.dataset.cartDec, 10);
      var qty  = getLineQty(line);
      if (qty <= 1) { scheduleRemoval(line); } else { changeQty(line, qty - 1); }
      return;
    }
    var inc = e.target.closest('[data-cart-inc]');
    if (inc) {
      var line = parseInt(inc.dataset.cartInc, 10);
      var incInput = document.querySelector('[data-cart-qty="' + line + '"]');
      var incMax = incInput && incInput.dataset.max ? parseInt(incInput.dataset.max, 10) : Infinity;
      var incQty = getLineQty(line);
      if (incQty >= incMax) {
        if (incInput && incInput.dataset.maxMsg) showToast(incInput.dataset.maxMsg);
        return;
      }
      changeQty(line, incQty + 1);
      return;
    }
    var rem = e.target.closest('[data-cart-remove]');
    if (rem) {
      scheduleRemoval(parseInt(rem.dataset.cartRemove, 10));
      return;
    }
    var upsellBtn = e.target.closest('[data-upsell-add]');
    if (upsellBtn) {
      upsellBtn.disabled = true;
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: parseInt(upsellBtn.dataset.upsellAdd, 10), quantity: 1 })
      })
      .then(function (res) {
        if (!res.ok) return res.json().then(function (d) { throw new Error(d.description || cfg.strings.errorGeneric); });
        return fetch('/cart.js', { headers: { 'Accept': 'application/json' } });
      })
      .then(function (res) { return res.json(); })
      .then(function (cart) {
        var shippingFree = cart.total_price >= cfg.threshold;
        var grandTotal   = shippingFree ? cart.total_price : cart.total_price + cfg.fee;
        var countEl = document.querySelector('[data-cart-count]');
        if (countEl) countEl.innerHTML = cart.item_count + ' ' + cfg.strings.items;
        var subtotalEl     = document.querySelector('[data-cart-subtotal]');
        var shippingValEl  = document.querySelector('[data-cart-shipping-value]');
        var shippingNoteEl = document.querySelector('[data-cart-shipping-note]');
        var grandTotalEl   = document.querySelector('[data-cart-grand-total]');
        if (subtotalEl)     subtotalEl.textContent     = formatMoney(cart.total_price);
        if (shippingValEl)  shippingValEl.textContent  = shippingFree ? cfg.strings.shippingFree : formatMoney(cfg.fee);
        if (shippingNoteEl) shippingNoteEl.textContent = shippingFree ? cfg.strings.shippingFreeNote : cfg.strings.shippingPaidNote;
        if (grandTotalEl)   grandTotalEl.textContent   = formatMoney(grandTotal);
        var freeShipFill  = document.querySelector('[data-free-ship-fill]');
        var freeShipLabel = document.querySelector('[data-free-ship-label]');
        var freeShipTrack = freeShipFill && freeShipFill.closest('[role="progressbar"]');
        if (freeShipFill) {
          var pct = Math.min(100, Math.round(cart.total_price / cfg.threshold * 100));
          freeShipFill.style.width = pct + '%';
          if (freeShipTrack) freeShipTrack.setAttribute('aria-valuenow', pct);
          if (shippingFree) {
            freeShipFill.classList.add('sw-free-ship-bar__fill--done');
            if (freeShipLabel) freeShipLabel.textContent = cfg.strings.freeShipUnlocked;
          } else {
            freeShipFill.classList.remove('sw-free-ship-bar__fill--done');
            if (freeShipLabel) {
              var rem2 = cfg.threshold - cart.total_price;
              freeShipLabel.textContent = cfg.strings.freeShipProgress.replace('__AMOUNT__', formatMoney(rem2));
            }
          }
        }
        var liveEl = document.getElementById('sw-cart-live');
        if (liveEl) liveEl.textContent = cart.item_count + ' ' + cfg.strings.items + ' — ' + formatMoney(grandTotal);
        showToast(cfg.strings.upsellAdded);
        upsellBtn.disabled = false;
      })
      .catch(function (err) {
        showToast(err.message || cfg.strings.errorGeneric);
        upsellBtn.disabled = false;
      });
    }
  });

  document.addEventListener('change', function (e) {
    if (settingValue) return;
    var input = e.target.closest('[data-cart-qty]');
    if (!input) return;
    var line     = parseInt(input.dataset.cartQty, 10);
    var maxStock = input.dataset.max ? parseInt(input.dataset.max, 10) : 999;
    var raw      = parseInt(input.value, 10);
    if (!isNaN(raw) && raw === 0) {
      settingValue = true;
      input.value = input.dataset.prevQty || 1;
      settingValue = false;
      scheduleRemoval(line);
      return;
    }
    var val = Math.max(1, Math.min(maxStock, isNaN(raw) ? 1 : raw));
    if (isNaN(raw) || raw < 1) showToast(cfg.strings.qtyMin);
    else if (raw > maxStock && input.dataset.maxMsg) showToast(input.dataset.maxMsg);
    settingValue = true;
    input.value = val;
    settingValue = false;
    changeQty(line, val);
  });
})();
</script>

{% schema %}
{
  "name": "t:general.cart",
  "settings": [
    {
      "type": "number",
      "id": "free_shipping_threshold",
      "label": "Free shipping threshold",
      "default": 2000,
      "info": "Orders above this amount qualify for free shipping."
    },
    {
      "type": "number",
      "id": "shipping_fee",
      "label": "Standard shipping fee",
      "default": 49
    },
    {
      "type": "number",
      "id": "low_stock_threshold",
      "label": "Low stock warning threshold",
      "default": 5,
      "info": "Show a warning on cart items when inventory is at or below this number."
    },
    {
      "type": "header",
      "content": "Empty cart"
    },
    {
      "type": "url",
      "id": "packages_url",
      "label": "\"Browse packages\" button URL",
      "info": "Link for the primary CTA on the empty cart page."
    },
    {
      "type": "header",
      "content": "Upsell section"
    },
    {
      "type": "checkbox",
      "id": "show_upsell",
      "label": "Show upsell products",
      "default": true
    },
    {
      "type": "collection",
      "id": "upsell_collection",
      "label": "Upsell collection",
      "info": "Up to 4 products from this collection appear in the 'You might also need' row."
    }
  ],
  "presets": [
    {
      "name": "t:general.cart"
    }
  ]
}
{% endschema %}
