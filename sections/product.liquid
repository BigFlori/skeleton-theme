{% comment %} Sonnwerk PDP — solar panel product detail page {% endcomment %}

{%- assign current_variant = product.selected_or_first_available_variant -%}

{% render 'pdp-styles' %}

{% render 'pdp-breadcrumb' %}

<section class="full-width">
  <div class="container pdp-split">
    {% render 'pdp-gallery', current_variant: current_variant %}
    <div id="buy-col-anchor">
      {% render 'pdp-buy', current_variant: current_variant %}
    </div>
  </div>
</section>

{% render 'pdp-keyspecs' %}
{% render 'pdp-compat' %}
{% render 'pdp-datasheet' %}
{% render 'pdp-sticky-bar', current_variant: current_variant %}
{% render 'pdp-scripts', current_variant: current_variant %}

{% schema %}
{
  "name": "Sonnwerk PDP",
  "settings": [
    { "type": "page", "id": "contact_page", "label": "Kapcsolat oldal" }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
