<section class="sw-cart-hero">
  <div class="container">
    <div class="sw-cart-hero__meta">
      <span class="eyebrow">{{ 'sections.cart.step' | t }}</span>
      <a href="{{ routes.root_url }}" class="sw-cart-hero__back">
        {{ 'sections.cart.continue_shopping' | t }}
      </a>
    </div>
    <h1 class="display sw-cart-hero__title">
      {{ 'sections.cart.title' | t }} <em>{{ 'sections.cart.title_em' | t }}</em>.
    </h1>
  </div>
</section>
