<div class="pdp-sticky-bar" id="pdp-sticky-bar" aria-hidden="true">
  <div class="container pdp-sticky-bar__inner">
    <div class="pdp-sticky-bar__thumb">
      {%- if product.featured_image -%}
        <img src="{{ product.featured_image | image_url: width: 120 }}" alt="{{ product.featured_image.alt | default: product.title | escape }}" width="54" height="54" loading="lazy">
      {%- endif -%}
    </div>
    <div style="flex:1;min-width:0;">
      <div style="font-size:14px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ product.title }}</div>
      <div class="mono" style="font-size:11px;color:var(--ink-mute);margin-top:2px;" id="pdp-sticky-price">
        1 × {{ current_variant.price | money_without_trailing_zeros }} = <strong style="color:var(--ink);">{{ current_variant.price | money_without_trailing_zeros }}</strong>
      </div>
    </div>
    <div class="pdp-buy__stepper" style="flex-shrink:0;">
      <button type="button" class="pdp-buy__stepper-btn" id="pdp-sticky-qty-down" aria-label="-">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14"/></svg>
      </button>
      <span class="pdp-buy__stepper-val" id="pdp-sticky-qty-display">1</span>
      <button type="button" class="pdp-buy__stepper-btn" id="pdp-sticky-qty-up" aria-label="+">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 5v14M5 12h14"/></svg>
      </button>
    </div>
    <button type="button" class="btn btn-primary" id="pdp-sticky-atc" style="flex-shrink:0;">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="9" cy="20" r="1.2"/><circle cx="17" cy="20" r="1.2"/><path d="M3 4h2l2.5 11.5a2 2 0 0 0 2 1.5h7.5a2 2 0 0 0 2-1.5L21 8H6"/></svg>
      {{ 'pdp.buy.add_to_cart' | t: price: '' | strip }}
    </button>
  </div>
</div>

<div class="sw-toast" id="pdp-toast" role="status" aria-live="polite">
  <svg class="sw-toast__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12l5 5L20 6"/></svg>
  <span id="pdp-toast-msg"></span>
</div>
