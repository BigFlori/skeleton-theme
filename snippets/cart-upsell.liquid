{%- if section.settings.upsell_collection != blank and section.settings.show_upsell -%}
  <section class="sw-cart-upsell">
    <div class="container">
      <div class="sw-cart-upsell__header">
        <div>
          <span class="eyebrow">{{ 'sections.cart.upsell_eyebrow' | t }}</span>
          <h2 class="display sw-cart-upsell__title">{{ 'sections.cart.upsell_title' | t }}</h2>
        </div>
        <a href="{{ section.settings.upsell_collection.url }}" class="sw-cart-upsell__all">
          {{ 'sections.cart.upsell_all' | t }}
        </a>
      </div>
      <div class="sw-cart-upsell__grid">
        {%- for product in section.settings.upsell_collection.products limit: 4 -%}
          <article class="sw-cart-upsell__card">
            {%- if product.featured_image -%}
              <div class="sw-cart-upsell__img-wrap">
                <img
                  src="{{ product.featured_image | image_url: width: 120 }}"
                  srcset="{{ product.featured_image | image_url: width: 120 }} 1x, {{ product.featured_image | image_url: width: 240 }} 2x"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  width="120"
                  height="120"
                  loading="lazy"
                  class="sw-cart-upsell__img"
                >
              </div>
            {%- else -%}
              <div class="sw-cart-upsell__img-placeholder" aria-hidden="true"></div>
            {%- endif -%}
            <div class="sw-cart-upsell__meta">
              <div class="mono sw-cart-upsell__vendor">{{ product.vendor }}</div>
              <h3 class="sw-cart-upsell__name">{{ product.title }}</h3>
            </div>
            <div class="sw-cart-upsell__footer">
              <span class="display sw-cart-upsell__price">{{ product.price | money }}</span>
              {%- if product.variants.size == 1 -%}
                <button
                  type="button"
                  class="btn btn-secondary sw-cart-upsell__add"
                  data-upsell-add="{{ product.selected_or_first_available_variant.id }}"
                  aria-label="{{ 'sections.cart.upsell_add' | t }}: {{ product.title | escape }}"
                >
                  {%- render 'icon', icon: 'plus', size: 13 -%}
                  {{ 'sections.cart.upsell_add' | t }}
                </button>
              {%- else -%}
                <a
                  href="{{ product.url }}"
                  class="btn btn-secondary sw-cart-upsell__add"
                  aria-label="{{ 'sections.cart.upsell_view' | t }}: {{ product.title | escape }}"
                >
                  {%- render 'icon', icon: 'arrow-right', size: 13 -%}
                  {{ 'sections.cart.upsell_view' | t }}
                </a>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}
